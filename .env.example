# Supabase (див. також QUICK_START.md / SETUP_SUPABASE_CLI.md)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# KeepinCRM (https://keepincrm.com/api-key та https://api.keepincrm.com/)
# Базовий шлях API з /v1, напр. https://api.keepincrm.com/v1
KEEPINCRM_API_KEY=
KEEPINCRM_BASE_URL=https://api.keepincrm.com/v1
# ID етапів угод через кому, які вважаються активними (порожньо — усі завантажені з API потрапляють у синк)
KEEPINCRM_ACTIVE_STAGE_IDS=
# Для перевірки викликів webhook: заголовок x-keepin-webhook-token, query ?token= або поле webhook_secret у JSON-тілі
KEEPINCRM_WEBHOOK_SECRET=
# Витрата при закупівлі сировини (POST /payments): гаманець і категорія
# KEEPINCRM_SUPPLIER_EXPENSE_PURSE_ID=
# KEEPINCRM_SUPPLIER_EXPENSE_PURSE_NAME=Петрович
# KEEPINCRM_SUPPLIER_EXPENSE_CATEGORY_ID=44
# KEEPINCRM_SUPPLIER_EXPENSE_CATEGORY_NAME=Закупівля Кора Сировина
# KEEPINCRM_SUPPLIER_EXPENSE_CURRENCY=UAH

CRON_SECRET=
